---
import { type CollectionEntry } from "astro:content";

export interface Props {
  publication: CollectionEntry<"publications">;
}

const { publication } = Astro.props;
---

<article
  class="reveal group relative flex flex-col overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition-all duration-300 hover:shadow-lg hover:shadow-primary/5"
>
  <div class="relative h-48 w-full overflow-hidden">
    {
      publication.data.image && (
        <img
          src={publication.data.image}
          alt={publication.data.title}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      )
    }
  </div>
  <div class="flex flex-1 flex-col p-6">
    <div class="flex-1">
      <p class="text-sm font-medium text-primary">
        {publication.data.author}
      </p>
      <div class="mt-2 block">
        <p class="text-xl font-semibold text-foreground">
          {publication.data.title}
        </p>
        <p class="mt-3 text-base text-muted-foreground line-clamp-3">
          {publication.data.description}
        </p>
      </div>
    </div>

    {
      publication.data.links && publication.data.links.length > 0 && (
        <div class="mt-6 space-y-2">
          {publication.data.links.map((link) => (
            <a
              href={link.url}
              class="inline-flex items-center text-sm font-medium text-primary hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="mr-2"
              >
                <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
                <path d="M14 2v4a2 2 0 0 0 2 2h4" />
              </svg>
              {link.text}
            </a>
          ))}
        </div>
      )
    }

    <div class="mt-6 flex items-center">
      <div class="flex space-x-1 text-sm text-muted-foreground">
        <time datetime={publication.data.pubDate.toISOString()}>
          {
            publication.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
              timeZone: "UTC",
            })
          }
        </time>
      </div>
    </div>
  </div>
</article>
