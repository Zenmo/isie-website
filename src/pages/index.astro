---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import Hero from "@/components/widgets/Hero.astro";
import Header from "@/components/ui/Header.astro";
import Paragraph from "@/components/ui/Paragraph.astro";
import ItemList from "@/components/ui/ItemList.astro";

const metadata = {
  title: `${siteConfig.name}`,
  description:
    "A modern and professional template for your web projects with Astro and Tailwind CSS. Boost your development with a solid foundation.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <Hero
    title={`
      Integrale modellering van het
      <br class="hidden md:block" />
      <span class="bg-clip-text text-transparent" style="color: var(--color-primary);">
          energiesysteem
      </span>
    `}
    description={`${siteConfig.description}`}
    actions={[
      {
        text: "Meer over het project",
        href: "/over-het-project",
        variant: "primary",
        icon: "lucide:notebook-text",
      },
      {
        text: "Resultaten",
        href: "/publicaties",
        variant: "secondary",
        icon: "lucide:chart-spline",
        ariaLabel: "Learn more about our services",
      },
    ]}
  />

  <div class="row">
    <style>
      .row {
        padding-left: 4rem;
        padding-right: 4rem;
      }
      @media (width > 60rem) {
        .row {
          display: flex;
          flex-direction: row;
          justify-content: center;
          align-items: flex-start;
          gap: 2rem;
        }
        .row > * {
          /* equal width content */
          flex-basis: 1rem;
          flex-grow: 1;
        }
      }
    </style>
    <section style="max-width: 40rem;">
      <Header>Wat is ISIE</Header>
      <Paragraph>
        ISIE (Instrumentarium en Standaarden voor Integrale
        Energiesysteem-analyse) is een samenwerkingsproject waarin
        toonaangevende modelleurs werken aan een betere, meer samenhangende
        analyse van het energiesysteem.
      </Paragraph>
    </section>
    <section style="max-width: 40rem;">
      <Header>Waarom is dit nodig?</Header>
      <Paragraph>
        Analyse van het energiesysteem gebeurt vaak met verschillende modellen,
        op verschillende schaalniveaus en met uiteenlopende aannames. Hierdoor
        ontstaan verschillen in uitkomsten en inzichten, en is het lastig om
        integrale beleidsvragen eenduidig te beantwoorden.
      </Paragraph>
      <Paragraph>
        ISIE pakt dit aan door modellen met elkaar te verbinden en te werken aan
        gedeelde standaarden.
      </Paragraph>
    </section>
    <section>
      <Header>Wat doen we?</Header>
      <ItemList
        items={[
          {
            title: "Modelkoppeling",
            description:
              "We verbinden modellen op lokaal, nationaal en Europees niveau.",
            icon: "lucide:link",
            iconClass: "bg-indigo-500/10 text-indigo-400",
          },
          {
            title: "Flexibiliteit en infrastructuur",
            description:
              "We verbeteren de representatie van flexibiliteit en infrastructuur in modellen.",
            icon: "lucide:zap",
            iconClass: "bg-orange-500/10 text-orange-400",
          },
          {
            title: "Standaarden en instrumentarium",
            description:
              "We ontwikkelen een gedeeld raamwerk voor consistente analyse.",
            icon: "lucide:drafting-compass",
            iconClass: "bg-teal-500/10 text-teal-400",
          },
        ]}
      />
    </section>
  </div>
</BaseLayout>
