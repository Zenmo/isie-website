---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Headline from "@/components/ui/Headline.astro";
import Pagination from "@/components/ui/Pagination.astro";
import PublicationItem from "@/components/publications/PublicationItem.astro";
import type { GetStaticPathsOptions } from "astro";
import Paragraph from "@/components/ui/Paragraph.astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const publicationEntries = await getCollection("publications");
  const sortedPublications = publicationEntries
    .filter((pub) => pub.data && pub.data.pubDate)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return paginate(sortedPublications, { pageSize: 6 });
}

const { page } = Astro.props;
const publications = page.data;

const metadata = {
  title: "Publicaties",
  description: "Publicaties en documenten van het ISIE project.",
};
---

<BaseLayout metadata={metadata}>
  <section class="relative px-4 py-8 sm:px-6 lg:px-8 md:py-12">
    <div class="absolute inset-0 z-0">
      <div
        class="absolute inset-0 bg-linear-to-br from-blue-500/5 via-transparent to-pink-500/5"
      >
      </div>
    </div>
    <div class="relative mx-auto max-w-5xl">
      <Headline
        title="Onze Publicaties"
        classes={{
          container: "reveal mb-12 text-center",
          title:
            "font-heading mb-4 text-4xl font-bold tracking-tight text-foreground md:text-6xl",
          subtitle: "mx-auto max-w-3xl text-xl text-muted-foreground",
        }}
      />
      <section style="max-width: 40rem; margin: 0 auto; padding: 2rem;">
        <Paragraph>
          Op deze pagina worden de resultaten van het ISIE-project gedeeld,
          waaronder rapporten, werkdocumenten en technische documentatie.
        </Paragraph>
        <Paragraph>
          Alle publicaties worden openbaar beschikbaar gesteld om transparantie
          en hergebruik te bevorderen.
        </Paragraph>
      </section>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {publications.map((pub) => <PublicationItem publication={pub} />)}
      </div>
      <Pagination page={page} />
    </div>
  </section>
</BaseLayout>
