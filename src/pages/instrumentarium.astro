---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/ui/Header.astro";
import Content from "@/components/widgets/Content.astro";
import IconedList from "@/components/ui/IconedList.astro";
import Paragraph from "@/components/ui/Paragraph.astro";
import BulletList from "@/components/ui/BulletList.astro";
import ContentWithImage from "@/components/ui/ContentWithImage.astro";
import Headline from "@/components/ui/Headline.astro";
import IntroParagraph from "@/components/ui/IntroParagraph.astro";

const metadata = {
  title: "Instrumentarium",
  description:
    "Het ISIE-instrumentarium bestaat uit een samenhangend geheel van modellen, datasets, " +
    "tools en standaarden waarmee integrale energiesysteemanalyse mogelijk wordt gemaakt.",
};
---

<BaseLayout metadata={metadata}>
  <Content title={metadata.title} description={metadata.description} />

  <section style="max-width: 40rem; margin: 0 auto; padding: 2rem;">
    <Paragraph>
      In plaats van één nieuw model te ontwikkelen, richt ISIE zich op het
      verbinden van bestaande modellen. Zo ontstaat een flexibel en uitbreidbaar
      systeem waarin verschillende modellen kunnen samenwerken.
    </Paragraph>

    <Paragraph>Het instrumentarium omvat onder andere:</Paragraph>

    <BulletList>
      <li>modelstandaarden</li>
      <li>datamodellen en uitwisselformaten</li>
      <li>koppelingen tussen modellen</li>
      <li>workflows voor integrale analyse</li>
    </BulletList>

    <Paragraph>
      Op dit moment zijn de volgende modellen onderdeel van het te ontwikkelen
      instrumentarium
    </Paragraph>
  </section>

  <div style="display: flex; gap: 2rem; flex-direction: column;">
    <ContentWithImage
      image="/lux-screenshot.png"
      imageAlt="Screenshot van het LUX dashboard"
    >
      <Headline tagline="Zenmo" title="LUX Energy Twin" />
      <Paragraph>
        Dit simulatiemodel werkt agent-based. Het ondersteunt meerdere
        energiedragers. Sterke punten:
      </Paragraph>

      <IconedList
        classes={{ container: "space-y-0" }}
        items={[
          {
            title: "Verkenning",
            description: "Stel scenario's samen en krijg direct feedback.",
            icon: "lucide:play",
            iconClass: "bg-indigo-500/10 text-indigo-400",
          },
          {
            title: "Performance",
            description: "Duizenden actoren met hoge tijdsresolutie.",
            icon: "lucide:zap",
            iconClass: "bg-orange-500/10 text-orange-400",
          },
          {
            title: "Nettopologie",
            description:
              "Verken oplossingen voor netcongestie door lokaal samen te werken.",
            icon: "lucide:git-pull-request-arrow",
            iconClass: "bg-teal-500/10 text-teal-400",
          },
        ]}
      />
    </ContentWithImage>

    <ContentWithImage
      image="/resourcefully-screenshot.png"
      imageAlt="Screenshot van het dashboard voor De Binnenhaven"
      style="--flex-direction: row-reverse"
    >
      <Headline tagline="Resourcefully" title="FLEX+" />
      <Paragraph>Sterke punten: </Paragraph>

      <IconedList
        classes={{ container: "space-y-0" }}
        items={[
          {
            title: "Batterijen en flex",
            description:
              "Bereken de optimale strategie voor de inzet van batterijen en slim laden.",
            icon: "lucide:ev-charger",
            iconClass: "bg-indigo-500/10 text-indigo-400",
          },
          {
            title: "Dashboard",
            description:
              "Uitgebreid dashboard om de uitkomsten van scenario's te vergelijken.",
            icon: "lucide:trending-up-down",
            iconClass: "bg-orange-500/10 text-orange-400",
          },
          {
            title: "Gevoeligheidsanalyse",
            description: "Bereken de impact van veranderende omstandigheden.",
            icon: "lucide:chart-candlestick",
            iconClass: "bg-teal-500/10 text-teal-400",
          },
        ]}
      />
    </ContentWithImage>
  </div>
</BaseLayout>
